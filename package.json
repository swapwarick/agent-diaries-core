{
  "name": "@agent-diaries/core",
  "version": "1.2.0",
  "description": "The lightweight, framework-agnostic memory layer for edge AI agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.reporter=lcov --coverage.reporter=text",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "agent-memory",
    "deduplication",
    "distributed-lock",
    "redis",
    "mongodb",
    "serverless",
    "idempotency",
    "task-queue"
  ],
  "author": "swapwarick_n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swapwarick/agent-diaries-core.git"
  },
  "bugs": {
    "url": "https://github.com/swapwarick/agent-diaries-core/issues"
  },
  "homepage": "https://github.com/swapwarick/agent-diaries-core#readme",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "ioredis": "^5.10.1",
    "mongodb": "^7.2.0",
    "pg": "^8.22.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9 || >=10 || >=11",
    "ioredis": ">=5",
    "mongodb": ">=6",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
